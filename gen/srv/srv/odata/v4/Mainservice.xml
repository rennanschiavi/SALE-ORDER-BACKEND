        <Annotation Term="Common.Label" String="{i18n>ChangedAt}"/>
      </Annotations>
      <Annotations Target="Mainservice.SalesOrderHeaders/modifiedBy">
        <Annotation Term="UI.HiddenFilter" Bool="true"/>
        <Annotation Term="UI.ExcludeFromNavigationContext" Bool="true"/>
        <Annotation Term="Core.Computed" Bool="true"/>
        <Annotation Term="Core.Description" String="{i18n>UserID.Description}"/>
        <Annotation Term="Common.Label" String="{i18n>ChangedBy}"/>
      </Annotations>
      <Annotations Target="Mainservice.SalesOrderHeaders/id">
        <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
      </Annotations>
      <Annotations Target="Mainservice.Costumers/id">
        <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
      </Annotations>
      <Annotations Target="Mainservice.Products/id">
        <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
      </Annotations>
      <Annotations Target="Mainservice.SalesOrderItems/id">
        <Annotation Term="Core.ComputedDefaultValue" Bool="true"/>
      </Annotations>
    </Schema>
  </edmx:DataServices>
